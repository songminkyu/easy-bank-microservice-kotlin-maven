{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "kotlin",
            "request": "attach",
            "name": "Kotlin: Attach (5005)",
            "port": 5005,
            "hostName": "localhost",
            "projectRoot": "${workspaceFolder}",
            "timeout": 30000
        },
        {
            "type": "java",
            "name": "Spring Boot-ConfigServerApplication<io.github.songminkyu-config-server>",
