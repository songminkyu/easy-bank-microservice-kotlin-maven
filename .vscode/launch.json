            "cwd": "${workspaceFolder}",
            "mainClass": "io.github.songminkyu.configserver.ConfigServerApplication",
            "projectName": "io.github.songminkyu-config-server",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot-EurekaServerApplication<io.github.songminkyu-eureka-server>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "io.github.songminkyu.eurekaserver.EurekaServerApplication",
            "projectName": "io.github.songminkyu-eureka-server",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "type": "java",
            "name": "Spring Boot-MessageApplication<io.github.songminkyu-message>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "io.github.songminkyu.message.MessageApplication",
            "projectName": "io.github.songminkyu-message",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
